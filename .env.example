# 서버 포트 (기본값: 8080, FE NEXT_PUBLIC_API_URL과 맞춰야 함)
PORT=8080

# 이미지 크기 (기본: 1344x768, 16:9 비율)
IMAGE_WIDTH=1344
IMAGE_HEIGHT=768

# Pollinations 모델: flux (고품질, 느림) | turbo (빠름, 저품질)
IMAGE_MODEL=flux

# 이미지 생성 타임아웃 (초)
TIMEOUT_SECONDS=60

# CORS 허용 Origin (쉼표 구분, 기본 * = 전체 허용)
# 운영 시에는 실제 FE 도메인으로 교체하세요.
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*
